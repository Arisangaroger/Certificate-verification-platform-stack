# ============================================================
#  CredentialRegistry — Environment Configuration
#  Network: Optimism Sepolia Testnet (L2)
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ============================================================

# ── Deployer Wallet ──────────────────────────────────────────
# This wallet deploys the smart contract (one-time use).
# 
# HOW TO GET:
# 1. Install MetaMask browser extension (https://metamask.io)
# 2. Create new account or use existing test account
# 3. Click account name → Account Details → Show Private Key
# 4. Copy private key (starts with 0x)
# 5. Add Optimism Sepolia network to MetaMask:
#    - Network Name: Optimism Sepolia
#    - RPC URL: https://sepolia.optimism.io
#    - Chain ID: 11155420
#    - Currency: ETH
#    - Block Explorer: https://sepolia-optimistic.etherscan.io
# 6. Fund with FREE test ETH: https://www.alchemy.com/faucets/optimism-sepolia
#    (Request 0.5 ETH - enough for deployment + operations)
#
# ⚠️ SECURITY: Use a dedicated wallet for testnet ONLY!
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# ── Platform Operator Gas Wallet ─────────────────────────────
# This wallet pays gas for all certificate minting operations.
# Your NestJS backend uses this to interact with the contract.
#
# HOW TO GET:
# Option A (RECOMMENDED FOR TESTING - simpler):
#   - Use SAME wallet as deployer above
#   - Copy same private key to OPERATOR_PRIVATE_KEY
#   - Copy the wallet address (0x...) to OPERATOR_WALLET_ADDRESS
#   - In MetaMask: Click account name → Copy Address
#
# Option B (Production setup - more secure):
#   - Create SECOND MetaMask account
#   - Copy its address (OPERATOR_WALLET_ADDRESS)
#   - Copy its private key (OPERATOR_PRIVATE_KEY)
#   - Fund with test ETH from faucet
#
# NOTE: This address is granted operator role during deployment
OPERATOR_WALLET_ADDRESS=0xYOUR_OPERATOR_WALLET_ADDRESS_HERE
OPERATOR_PRIVATE_KEY=0xYOUR_OPERATOR_PRIVATE_KEY_HERE

# ── RPC Endpoints ─────────────────────────────────────────────
# Optimism Sepolia (testnet) — YOUR DEPLOYMENT TARGET
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# Alternative RPC providers (if you need higher rate limits):
# Alchemy: https://opt-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Infura:  https://optimism-sepolia.infura.io/v3/YOUR_PROJECT_ID

# Optimism Mainnet (IGNORE FOR NOW - future production only)
OPTIMISM_MAINNET_RPC_URL=https://mainnet.optimism.io

# ── Contract Address (filled AFTER deployment) ───────────────
# LEAVE EMPTY until you deploy!
# 
# After running deployment:
#   npx hardhat ignition deploy ./ignition/modules/CredentialRegistryModule.js --network optimism-sepolia
#
# Copy the contract address from terminal output and paste here.
# Then copy this SAME address to your NestJS backend .env file.
CREDENTIAL_REGISTRY_ADDRESS=

# ── Etherscan Verification (OPTIONAL) ────────────────────────
# API key for verifying contract source code on block explorer.
# Makes your contract readable on Etherscan.
#
# HOW TO GET:
# 1. Visit: https://optimistic.etherscan.io/
# 2. Sign up / Login (free account)
# 3. Go to: My Profile → API Keys
# 4. Click "Add" to create new API key
# 5. Copy key and paste here
#
# Leave empty if you don't need public verification (works fine without it)
OPTIMISM_ETHERSCAN_API_KEY=

# ── Gas Reporter (optional) ──────────────────────────────────
# Uncomment to see gas costs during testing
# REPORT_GAS=true
