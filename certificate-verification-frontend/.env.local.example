# Backend API Configuration
# The backend runs on the FIXED port 3000, so the frontend must call it here.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# The frontend dev/start server is pinned to the FIXED port 3001
# via the "dev" and "start" scripts in package.json (next -p 3001).
# Do not change these ports — the backend CORS and QR verification links depend on them.
